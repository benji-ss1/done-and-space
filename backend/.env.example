# ============================================================
# DONE & SPACE PROPERTIES — BACKEND ENVIRONMENT
# Copy to .env and fill in values. Never commit .env to git.
# ============================================================

NODE_ENV=development
PORT=3001

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Supabase — create a NEW project at supabase.com
# Use the SERVICE ROLE key (not anon) for backend
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-64-char-random-hex
JWT_REFRESH_SECRET=replace-with-different-64-char-random-hex
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Supabase Storage bucket name
STORAGE_BUCKET_PROPERTIES=property-images
STORAGE_BUCKET_DOCUMENTS=property-documents
STORAGE_BUCKET_CVS=agent-cvs
